{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "additionalLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "gateways": {
      "type": "object",
      "properties": {
        "default": {
          "type": "object",
          "properties": {
            "metadata": {
              "type": "object",
              "properties": {
                "annotations": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            },
            "spec": {
              "type": "object",
              "properties": {
                "gatewayClassName": {
                  "type": "string"
                },
                "listener": {
                  "type": "object",
                  "properties": {
                    "allowedRoutes": {
                      "type": "object",
                      "properties": {
                        "namespaces": {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "string",
                              "enum": [
                                "All",
                                "Same"
                              ]
                            }
                          },
                          "required": [
                            "from"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "namespaces"
                      ],
                      "additionalProperties": false
                    },
                    "port": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    },
                    "protocol": {
                      "type": "string",
                      "enum": [
                        "HTTP",
                        "HTTPS"
                      ]
                    }
                  },
                  "required": [
                    "allowedRoutes",
                    "port",
                    "protocol"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "gatewayClassName",
                "listener"
              ],
              "additionalProperties": false
            },
            "tlsSecretGroups": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "parentDomain": {
                    "type": "string",
                    "pattern": "^(trydave\\.com|daveapi\\.com|daveapi\\.io)$"
                  },
                  "secretName": {
                    "type": "string",
                    "maxLength": 253
                  }
                },
                "required": [
                  "parentDomain",
                  "secretName"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "spec"
          ],
          "additionalProperties": false
        },
        "items": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "maxLength": 63,
                "pattern": "^[a-z]([-a-z0-9]*[a-z0-9])?$"
              },
              "enabled": {
                "type": "boolean"
              },
              "rawSpec": {
                "type": "boolean"
              },
              "spec": {
                "type": "object",
                "properties": {
                  "gatewayClassName": {
                    "type": "string"
                  },
                  "listeners": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 64,
                    "items": {
                      "type": "object",
                      "properties": {
                        "hostname": {
                          "type": "string",
                          "pattern": "^([a-zA-Z0-9]+(-[a-zA-Z0-9]+)*\\.)*(trydave\\.com|daveapi\\.com|daveapi\\.io)$"
                        },
                        "name": {
                          "type": "string",
                          "maxLength": 63
                        },
                        "port": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 65535
                        },
                        "protocol": {
                          "type": "string",
                          "enum": [
                            "HTTP",
                            "HTTPS"
                          ]
                        },
                        "allowedRoutes": {
                          "type": "object",
                          "properties": {
                            "namespaces": {
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string",
                                  "enum": [
                                    "All",
                                    "Same"
                                  ]
                                }
                              },
                              "required": [
                                "from"
                              ],
                              "additionalProperties": false
                            }
                          },
                          "required": [
                            "namespaces"
                          ],
                          "additionalProperties": false
                        },
                        "tls": {
                          "type": "object",
                          "properties": {
                            "mode": {
                              "type": "string",
                              "enum": [
                                "Terminate",
                                "Passthrough"
                              ]
                            },
                            "certificateRefs": {
                              "type": "array",
                              "minItems": 1,
                              "items": {
                                "type": "object",
                                "properties": {
                                  "group": {
                                    "type": "string",
                                    "const": ""
                                  },
                                  "kind": {
                                    "type": "string",
                                    "const": "Secret"
                                  },
                                  "name": {
                                    "type": "string",
                                    "maxLength": 253
                                  }
                                },
                                "required": [
                                  "name"
                                ],
                                "additionalProperties": false
                              }
                            }
                          },
                          "required": [
                            "certificateRefs"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "required": [
                  "listeners"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "name",
              "spec"
            ],
            "if": {
              "required": [
                "rawSpec"
              ],
              "properties": {
                "rawSpec": {
                  "const": true
                }
              }
            },
            "then": {
              "properties": {
                "spec": {
                  "required": [
                    "gatewayClassName",
                    "listeners"
                  ],
                  "properties": {
                    "listeners": {
                      "items": {
                        "required": [
                          "hostname",
                          "port",
                          "protocol",
                          "allowedRoutes",
                          "name"
                        ]
                      }
                    }
                  }
                }
              }
            },
            "else": {
              "properties": {
                "spec": {
                  "properties": {
                    "listeners": {
                      "items": {
                        "required": [
                          "hostname"
                        ]
                      }
                    }
                  }
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "required": [
        "default",
        "items"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "enabled",
    "gateways"
  ]
}
