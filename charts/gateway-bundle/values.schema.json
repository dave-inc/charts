{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "additionalLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "gatewayAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "gatewaySpec": {
      "type": "object",
      "properties": {
        "gatewayClassName": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "gatewayClassName"
      ]
    },
    "listenerSpec": {
      "type": "object",
      "properties": {
        "allowedRoutes": {
          "type": "object",
          "properties": {
            "namespaces": {
              "type": "object",
              "properties": {
                "from": {
                  "type": "string",
                  "enum": [
                    "All",
                    "Same"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "port": {
          "type": "integer"
        },
        "protocol": {
          "type": "string",
          "enum": [
            "HTTP",
            "HTTPS"
          ]
        }
      },
      "required": [
        "allowedRoutes",
        "port",
        "protocol"
      ],
      "additionalProperties": false
    },
    "gateways": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "additionalLabels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "gatewayAnnotations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "gatewaySpec": {
            "type": "object",
            "properties": {
              "gatewayClassName": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "listeners": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^([a-zA-Z0-9]+(-[a-zA-Z0-9]+)*\\.)*(trydave\\.com|daveapi\\.com|daveapi\\.io)$"
                },
                {
                  "type": "object",
                  "properties": {
                    "listenerSpec": {
                      "type": "object",
                      "properties": {
                        "allowedRoutes": {
                          "type": "object",
                          "properties": {
                            "namespaces": {
                              "type": "object",
                              "properties": {
                                "from": {
                                  "type": "string",
                                  "enum": [
                                    "All",
                                    "Same"
                                  ]
                                }
                              },
                              "additionalProperties": false
                            }
                          },
                          "additionalProperties": false
                        },
                        "port": {
                          "type": "integer"
                        },
                        "protocol": {
                          "type": "string",
                          "enum": [
                            "HTTP",
                            "HTTPS"
                          ]
                        },
                        "hostname": {
                          "type": "string",
                          "pattern": "^([a-zA-Z0-9]+(-[a-zA-Z0-9]+)*\\.)*(trydave\\.com|daveapi\\.com|daveapi\\.io)$"
                        },
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "hostname"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "listenerSpec"
                  ]
                }
              ]
            }
          }
        },
        "additionalProperties": false,
        "required": [
          "listeners"
        ]
      }
    }
  }
}
