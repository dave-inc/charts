                          "items": {
                            "type": "object",
                            "properties": {
                              "path": {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": [
                                      "PathPrefix",
                                      "PathExact",
                                      "PathRegex"
                                    ]
