      "required": [
        "enabled",
        "certificate",
        "backendConfig"
      ],
      "oneOf": [
        {
          "required": [
            "hosts"
          ],
          "$comment": "If hosts is defined, paths should not be defined"
        },
        {
          "required": [
            "paths"
          ],
          "$comment": "If paths is defined, hosts should not be defined"
        }
      ],
      "additionalProperties": false
