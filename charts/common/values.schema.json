          "additionalProperties": {
            "type": "string"
          },
          "required": []
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "csmStaticIpName": {
                "type": "string",
                "$comment": "Only used if canary.enabled is true. Optional, If not set, a name is generated using Release.Name with '-csm'"
              },
              "staticIpName": {
                "type": "string"
              },
              "annotations": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "required": []
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "backend": {
                      "type": "object",
                      "properties": {
                        "service": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string",
                              "pattern": "^[a-z0-9][a-z0-9-]+-ca$"
                            },
                            "port": {
                              "type": "object",
                              "properties": {
                                "number": {
                                  "type": "integer",
                                  "minimum": 1,
                                  "maximum": 65535
                                }
                              },
                              "required": [
                                "number"
                              ],
                              "additionalProperties": false
                            },
                            "targetPort": {
                              "type": "integer",
                              "minimum": 1,
                              "maximum": 65535
                            },
                            "canary": {
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "name",
                            "port",
                            "targetPort"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "service"
                      ],
                      "additionalProperties": false
                    },
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string",
                      "enum": [
                        "ImplementationSpecific",
                        "Prefix",
                        "Exact"
                      ]
                    }
                  },
                  "required": [
                    "backend",
                    "path",
                    "pathType"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "backend": {
                "type": "object",
                "properties": {
                  "service": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9-]+-ca$"
